<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.shreeniketh.hotelmanagement.controller.CustomersController">
    <children>
        <VBox spacing="4.0" styleClass="screen-header">
            <children>
                <Label styleClass="screen-title" text="Customer Management" />
                <Label styleClass="helper-text" text="Create customer records before check-in, then check them in from the selected row. Check-out is handled in Billing." wrapText="true" />
            </children>
        </VBox>
        <VBox spacing="10.0" styleClass="surface-panel">
            <children>
                <Label styleClass="section-title" text="Customer list" />
                <TableView fx:id="customerTable" prefHeight="310.0">
                    <columns>
                        <TableColumn fx:id="customerIdColumn" prefWidth="120.0" text="Customer ID" />
                        <TableColumn fx:id="customerNameColumn" prefWidth="170.0" text="Name" />
                        <TableColumn fx:id="phoneNumberColumn" prefWidth="130.0" text="Phone" />
                        <TableColumn fx:id="roomNoColumn" prefWidth="90.0" text="Room" />
                        <TableColumn fx:id="nightsBoughtColumn" prefWidth="90.0" text="Nights" />
                        <TableColumn fx:id="checkedInColumn" prefWidth="90.0" text="In" />
                        <TableColumn fx:id="checkedOutColumn" prefWidth="90.0" text="Out" />
                    </columns>
                </TableView>
            </children>
        </VBox>
        <VBox spacing="10.0" styleClass="surface-panel">
            <children>
                <Label styleClass="section-title" text="Customer details" />
                <Label fx:id="customerIdPreviewLabel" styleClass="helper-text" text="Next ID: C001" />
                <GridPane hgap="12.0" vgap="12.0">
                    <padding>
                        <Insets top="4.0" />
                    </padding>
                    <children>
                        <Label text="Customer ID" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <TextField fx:id="customerIdField" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        <Label text="Name" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <TextField fx:id="customerNameField" promptText="Alex" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <Label text="Phone" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <TextField fx:id="phoneNumberField" promptText="9876543210" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <Label text="Room No" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                        <ComboBox fx:id="roomNoChoiceBox" prefWidth="180.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                        <Label text="Nights Bought" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                        <TextField fx:id="nightsField" promptText="3" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                    </children>
                </GridPane>
                <HBox spacing="10.0" styleClass="action-bar">
                    <children>
                        <Button styleClass="primary-button" onAction="#createCustomer" text="Create Customer" />
                        <Button onAction="#checkInCustomer" text="Check In" />
                        <Button onAction="#refreshCustomers" text="Refresh" />
                        <Button onAction="#refreshRoomOptions" text="Reload Rooms" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>