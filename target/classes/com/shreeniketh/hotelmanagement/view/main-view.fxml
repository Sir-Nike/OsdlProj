<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="760.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.shreeniketh.hotelmanagement.controller.MainController">
    <top>
        <HBox spacing="12.0" styleClass="header-bar" BorderPane.alignment="CENTER_LEFT">
            <padding>
                <Insets bottom="14.0" left="18.0" right="18.0" top="14.0" />
            </padding>
            <children>
                <VBox spacing="2.0">
                    <children>
                        <Label styleClass="app-title" text="Hotel Management System" />
                        <Label styleClass="helper-text" text="Simple room, customer, and billing control" />
                    </children>
                </VBox>
                <HBox HBox.hgrow="ALWAYS" />
                <Button fx:id="clearDataButton" styleClass="icon-button" onAction="#clearAllData" text="🗑" />
                <Button fx:id="themeToggleButton" styleClass="icon-button" onAction="#toggleTheme" text="☾" />
            </children>
        </HBox>
    </top>
    <left>
        <VBox spacing="10.0" prefWidth="210.0" styleClass="nav-panel" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="18.0" left="18.0" right="14.0" top="18.0" />
            </padding>
            <children>
                <Label styleClass="nav-heading" text="Sections" />
                <Label styleClass="helper-text" text="Pick one area to work in." wrapText="true" />
                <Button maxWidth="Infinity" onAction="#showRooms" text="Rooms" />
                <Button maxWidth="Infinity" onAction="#showCustomers" text="Customers" />
                <Button maxWidth="Infinity" onAction="#showBilling" text="Billing" />
            </children>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentPane" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="18.0" left="18.0" right="18.0" top="18.0" />
            </padding>
        </StackPane>
    </center>
</BorderPane>